{
  "name": "QMS DMS Server",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r requirements.txt && npm install -g docx",
  "forwardPorts": [
    5151
  ],
  "portsAttributes": {
    "5151": {
      "label": "QMS DMS Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-python.debugpy"
      ]
    }
  }
}